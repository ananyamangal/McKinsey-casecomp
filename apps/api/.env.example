# ---------------------------------------------------------------------------
# Halo API — environment configuration
# Copy to `.env` and adjust. All values have sane zero-config defaults.
# ---------------------------------------------------------------------------

# Application environment: local | staging | production
ENV=local

# Database. Defaults to a zero-config local SQLite file.
# For PostgreSQL use e.g.:
#   DATABASE_URL=postgresql+psycopg2://halo:halo@localhost:5432/halo
DATABASE_URL=sqlite:///./halo.db

# Redis / Celery (workers are optional in dev)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Security — CHANGE JWT_SECRET in production
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS — comma separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
